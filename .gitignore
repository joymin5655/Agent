# =============================================================================
# AI-agnostic agent framework — runtime + secrets exclusions
# =============================================================================
# Applies to anyone who clones this repo for development.
# Project consumers get a separate `.gitignore` via `setup.sh --project`.

# --- OS / IDE -----------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# --- Build / dependency caches ------------------------------------------------
node_modules/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/

# --- Secrets / env ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template
secrets/

# --- Runtime state (AI session locks, logs, telemetry) ------------------------
.agent/locks/
.agent/logs/
.agent/state/
.agent/workers/
.claude/locks/
.claude/logs/
.claude/state.local/
.claude/settings.local.json
.claude/projects/
.claude/sessions/
.claude/telemetry/
.codex/sessions/
.codex/log/
.codex/tmp/
.gemini/history/
.gemini/tmp/

# --- Local working directories ------------------------------------------------
.worktrees/
.agents/
.omc/
.codegraph/

# Personal context anchor for the repo owner's local sessions — not shipped.
# Consumers get their own CLAUDE.md via `setup.sh --project` (templates/).
/CLAUDE.md
*.lock
*.jsonl
# ...but eval datasets are source, not runtime artifacts — JSONL is the eval standard format.
!evals/datasets/*.jsonl
*.log

# --- Generated / temporary ----------------------------------------------------
tmp/
.tmp/
coverage/
*.tsbuildinfo
