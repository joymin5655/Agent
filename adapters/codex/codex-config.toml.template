# Codex CLI configuration template.
# Copy to ~/.codex/config.toml (or merge into existing).
# Replace {{FRAMEWORK_ROOT}} with the absolute path to your Agent/ checkout.

# Profile: route Codex's shell tool through the framework's gate hooks.
# Requires codex-shell-wrap.sh on PATH (see adapters/codex/README.md).
[tools.shell]
command = "{{FRAMEWORK_ROOT}}/adapters/codex/codex-shell-wrap.sh"

# Project context file (Codex reads AGENTS.md per-project; see template).
# Codex also reads ~/.codex/AGENTS.md as a global instruction file.
project_doc = "AGENTS.md"

# Sandbox — Codex's permission model. Recommended for use alongside this
# framework: trust prompts so the wrapper can BLOCK actions before they hit
# the sandbox.
[sandbox]
mode = "workspace-write"
allow_network = false

# Skills directory (optional — set if using ~/.codex/skills layout).

# Model tier profiles (docs/model-routing.md). The unprefixed default model is
# the workhorse (MID) tier; these profiles reach the LOW and TOP rungs with
# `codex --profile quick` / `codex --profile deep`. Model IDs below are a
# 2026-07 snapshot — substitute the current light/top models for your account.
# Raise model_reasoning_effort within a rung before promoting a rung up.
[profiles.quick]        # LOW: mechanical fixes, lookups, fan-out workers
model = "gpt-5.4-mini"
model_reasoning_effort = "low"

[profiles.deep]         # TOP: planning, architecture, security review
model = "gpt-5.5"
model_reasoning_effort = "high"
# If your account exposes a max-tier variant, pin it here instead (its
# dedicated top effort level is exclusive to that tier).
