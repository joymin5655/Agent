{
  "_comment": "Master agent registry template. Copy to .agent/agents/master-registry.json in your project and edit to suit. The supervisor.py hook reads this to suggest specialists for incoming work.",
  "version": 1,
  "agents": [
    {
      "id": "code-reviewer",
      "description": "Reviews diffs for quality, correctness, security, performance.",
      "matches": {
        "keywords": ["review", "check this code", "code review", "look over"],
        "tools": [],
        "file_globs": []
      },
      "aliases": ["reviewer", "diff-reviewer"],
      "model": "sonnet",
      "memory_scope": "local"
    },
    {
      "id": "architect",
      "description": "Designs implementation plans for new features or refactors.",
      "matches": {
        "keywords": ["design", "architecture", "how should we structure", "plan the"],
        "tools": [],
        "file_globs": []
      },
      "aliases": ["designer", "code-architect"],
      "model": "opus",
      "memory_scope": "project"
    },
    {
      "id": "security-reviewer",
      "description": "Audits for OWASP Top 10, secret exposure, auth/authz bugs.",
      "matches": {
        "keywords": ["security", "auth", "owasp", "vulnerability", "secret leak"],
        "tools": ["Write", "Edit"],
        "file_globs": ["**/auth/**", "**/secrets/**", "**/.env*"]
      },
      "aliases": [],
      "model": "sonnet",
      "memory_scope": "local"
    },
    {
      "id": "test-engineer",
      "description": "Writes / fixes unit, integration, and E2E tests.",
      "matches": {
        "keywords": ["test", "spec", "fixture", "tdd"],
        "tools": [],
        "file_globs": ["**/*.test.*", "**/*.spec.*", "**/tests/**", "**/__tests__/**"]
      },
      "aliases": ["test-writer", "tdd-guide"],
      "model": "sonnet",
      "memory_scope": "local"
    },
    {
      "id": "build-error-resolver",
      "description": "Diagnoses and fixes build / TypeScript / linker errors.",
      "matches": {
        "keywords": ["build error", "tsc error", "compile fail", "lint fail"],
        "tools": ["Bash"],
        "file_globs": []
      },
      "aliases": ["typescript-reviewer", "build-fixer"],
      "model": "sonnet",
      "memory_scope": "local"
    }
  ]
}
