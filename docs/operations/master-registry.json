{
  "$schema": "https://airlens-platform/master-registry-schema.json",
  "version": "1.0.0",
  "description": "AirLens 플랫폼 통합 에이전트 마스터 레지스트리 — 7-필드 schema + 3-tier 분류. F2 D-H6 합의(루트 .claude/ + Obsidian mirror, tier1만 worktree isolation 강제)를 코드화.",
  "updated": "2026-04-28",
  "source_plan": "Obsidian-airlens/raw/plans/airlens-master-registry-2026-04-28.md",
  "field_schema": {
    "id": "kebab-case agent identifier",
    "tier": "1 (bootstrap/high-risk) | 2 (specialist/implementer) | 3 (reviewer/read-mostly)",
    "scope": "global | AirLens-web | AirLens-models | AirLens-app | platform",
    "domain": "frontend | backend | ml | db | operations | design | general",
    "purpose": "단문 (1줄) 책임 기술",
    "tools": "Allowed tool names array",
    "path": "absolute or repo-relative path to agent .md or registry"
  },
  "tier_policy": {
    "tier1": {
      "definition": "부트스트랩 / DB 마이그레이션 / 네이티브 빌드 / ML 학습 등 위험도 높은 작업. F2 D-H6에 따라 worktree isolation 권장.",
      "worktree_isolation": "recommended"
    },
    "tier2": {
      "definition": "일반 구현 specialist (component-builder, edge-fn-dev, test-engineer 등). 코드 작성 권한 보유.",
      "worktree_isolation": "optional"
    },
    "tier3": {
      "definition": "보조/검토 reviewer (style-reviewer, security-reviewer 등). 코드 직접 작성 권한 없음, read-mostly.",
      "worktree_isolation": "not_required"
    }
  },
