{
  "version": "1.0.0",
  "description": "Supervisor 워크플로우 템플릿 — 의도별 에이전트 디스패치 순서 정의",
  "workflows": {
    "feature-dev": {
      "description": "Plan → 전문가 구현 → 리뷰",
      "trigger": "FEATURE",
      "steps": [
        {
          "name": "설계",
          "agents": ["Plan"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        },
        {
          "name": "구현",
          "agents": ["{matched_specialist}"],
          "parallel": false,
          "model": "{dept_model}",
          "resultBudget": "full"
        },
        {
          "name": "검증",
          "agents": ["style-reviewer"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        }
      ]
    },
    "ui-design-dev": {
      "description": "Plan → 디자인 디렉션 → 컴포넌트 구현 → UX/스타일 리뷰",
      "trigger": "FEATURE",
      "triggerKeywords": ["UI", "UX", "디자인", "브랜드", "랜딩", "히어로", "온보딩", "전환", "redesign", "landing", "hero", "onboarding"],
      "steps": [
        {
          "name": "설계",
          "agents": ["Plan"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        },
        {
          "name": "디자인 디렉션",
          "agents": ["ui-ux-director"],
          "parallel": false,
          "model": "opus",
          "resultBudget": "600 words"
        },
        {
          "name": "구현",
          "agents": ["component-builder"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "full"
        },
        {
          "name": "검증",
          "agents": ["ux-reviewer", "style-reviewer"],
          "parallel": true,
          "model": "sonnet",
          "resultBudget": "250 words"
        }
      ]
    },
    "multi-dept": {
      "description": "Plan → 전문가들 병렬 → 리뷰+테스트 병렬",
      "trigger": "MULTI_DEPT",
      "steps": [
        {
          "name": "설계",
          "agents": ["Plan"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        },
        {
          "name": "구현",
          "agents": ["{matched_agents}"],
          "parallel": true,
          "model": "{dept_model}",
          "resultBudget": "full"
        },
        {
          "name": "검증",
          "agents": ["style-reviewer", "test-engineer"],
          "parallel": true,
          "model": "sonnet",
          "resultBudget": "200 words"
        }
      ]
    },
    "bug-fix": {
      "description": "전문가 진단 → 테스트 검증",
      "trigger": "FEATURE",
      "triggerKeywords": ["버그", "bug", "fix", "고장", "에러", "error", "깨진", "broken"],
      "steps": [
        {
          "name": "진단+수정",
          "agents": ["{matched_specialist}"],
          "parallel": false,
          "model": "{dept_model}",
          "resultBudget": "full"
        },
        {
          "name": "검증",
          "agents": ["test-engineer"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        }
      ]
    },
    "query": {
      "description": "전문가 분석 제공",
      "trigger": "QUERY",
      "steps": [
        {
          "name": "분석",
          "agents": ["{matched_specialist}"],
          "parallel": false,
          "model": "sonnet",
          "resultBudget": "200 words"
        }
      ]
    }
  },
  "modelTiers": {
    "haiku": "경량 (로깅, 기록, 간단 검증)",
    "sonnet": "구현 (코딩, 리뷰, 분석)",
    "opus": "설계 (아키텍처, 복잡한 분석)"
  }
}
