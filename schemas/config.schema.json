{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/joymin5655/Agent/main/schemas/config.schema.json",
  "title": "Agent Harness Project Config",
  "type": "object",
  "required": [
    "schema_version",
    "project_name",
    "mode",
    "strict",
    "log_dir",
    "state_dir",
    "session_lock_file",
    "supervisor"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "knowledge_base_path": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["advisory", "strict"]
    },
    "strict": {
      "type": "boolean"
    },
    "log_dir": {
      "type": "string"
    },
    "state_dir": {
      "type": "string"
    },
    "session_lock_file": {
      "type": "string"
    },
    "supervisor": {
      "type": "object",
      "required": [
        "max_prompt_len",
        "require_plan_for_high_risk",
        "require_specialist_evidence"
      ],
      "properties": {
        "max_prompt_len": {
          "type": "integer",
          "minimum": 1
        },
        "require_plan_for_high_risk": {
          "type": "boolean"
        },
        "require_specialist_evidence": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
