# hook-config.yml — per-project customisation for the agent framework.
#
# Copy this file to your project root and edit. The framework's hooks
# read it on every invocation, so changes take effect immediately.
#
# All fields are OPTIONAL — defaults are documented inline.

# ---------------------------------------------------------------------------
# Risk areas — the 5 areas that automation must never act on unilaterally.
# See rules/policy/security-guards.md for the policy.
# ---------------------------------------------------------------------------
risk_areas:
  data:
    # Production data migrations. Regex applied to changed file paths.
    pattern: '^.*/migrations/.*\.sql$'
    decision: ask   # ask | deny  (default: ask)

  secrets:
    # Files / patterns that constitute secret leak. ALWAYS deny — no override.
    paths:
      - 'secrets/**'
      - '.env'
      - '.env.local'
      - '.env.production'
    # Keyword identifiers that trigger secret-content-scan.py.
    keywords:
      - SERVICE_ROLE_KEY
      - API_TOKEN
      - API_KEY
      - STRIPE_SECRET_KEY
      - POLAR_API_KEY
      - PRIVATE_KEY
    decision: deny

  deploy:
    # Function / worker / deploy bundles.
    pattern: '^.*/functions/.*/index\.ts$'
    decision: ask

  payment:
    # Billing / payment code.
    pattern: '(billing/|stripe|polar|iap|revenue-cat)'
    decision: ask

  domain-output:
    # Project-specific: uncertainty / quality / signed-prediction fields
    # whose net removal should block. Empty = no check.
    pattern: '(uncertainty|confidence_p\d+|grade_letter)'
    decision: advisory   # advisory | ask | deny

# ---------------------------------------------------------------------------
# Resource mutex — see rules/multi-agent-worktree.md R4.
# Maps Bash commands / MCP tools to a mutex name. Concurrent sessions block.
# ---------------------------------------------------------------------------
resources:
  production-db:
    triggers:
      - 'supabase db push'
      - 'supabase migration (up|apply)'
      - 'mcp__supabase__apply_migration'
    auto_expire_minutes: 60

  edge-function-deploy:
    triggers:
      - 'supabase functions deploy'
      - 'mcp__supabase__deploy_edge_function'
    auto_expire_minutes: 30

  production-deploy:
    triggers:
      - 'wrangler pages deploy'
      - 'fly deploy'
      - 'gh workflow run .*deploy.*'
    auto_expire_minutes: 30

# ---------------------------------------------------------------------------
# Hardcoding policy — paths exempt from check-hardcoding.py / check-staged.py.
# ---------------------------------------------------------------------------
hardcoding:
  exempt_globs:
    - 'config.ts'
    - 'config.js'
    - 'types.ts'
    - 'types.js'
    - 'tailwind.config.*'
    - 'vite.config.*'
    - 'tsconfig*'
    - '.test.*'
    - '.spec.*'
    - 'test/'
    - '__tests__/'
    - 'docs/'
    - 'wiki/'

  scan_extensions:
    - .ts
    - .tsx
    - .js
    - .jsx
    - .py

# ---------------------------------------------------------------------------
# Session coordination
# ---------------------------------------------------------------------------
session:
  heartbeat_interval_seconds: 300
  stale_after_minutes: 30
  worktree_prefix: '.worktrees'
  lock_dir: '.agent/locks'
  log_dir: '.agent/logs'
  # completion_tests — LIVE (read by core/hooks/session-quality-gate.py, P3-1).
  # Shell commands run on the FIRST Stop of a response. If any exits non-zero
  # (or times out), the session is blocked from ending until it passes — you
  # cannot claim "done" while tests fail. A second Stop passes (intentional
  # override), as does AGENT_QUALITY_GATE_BLOCK=0 (advisory). Commands run at
  # the project's OWN trust level (same as your package.json scripts); unset or
  # empty = the completion gate does nothing. Per-command timeout:
  # AGENT_COMPLETION_TEST_TIMEOUT seconds (default 120).
  completion_tests: []
  #   - "npm test --silent"
  #   - "npx tsc --noEmit"

# ---------------------------------------------------------------------------
# Goal mode (supervisor-goal.sh)
# ---------------------------------------------------------------------------
goal_mode:
  default_budget: null   # null = no budget; integer = token budget
  graceful_wrap_wiki_dir: 'wiki/synthesis'
  graceful_wrap_memory_dir: null   # set to enable optional memory stub

# ---------------------------------------------------------------------------
# Optional: project-specific hook script overrides
# ---------------------------------------------------------------------------
# hooks:
#   pre_tool_guard: 'custom/my-pre-tool-guard.sh'
#   secret_content_scan: 'custom/my-secret-scan.py'

# ---------------------------------------------------------------------------
# Secret-scan extensions — loaded at runtime by core/hooks/hook_config.py from
# `.agent/hook-config.yml` (copy this file there to activate). This block and
# `session.completion_tests` (above) are the runtime-live parts of this file;
# everything else (risk_areas: / resources: / hardcoding: / the rest of
# session:) is declarative documentation only, not read by any hook. See
# docs/customization.md part 2.
#
# ADDITIVE ONLY: these entries can only ADD secret patterns / exempt paths /
# credential key names on top of secret-content-scan.py's built-ins. There is
# no way to remove, disable, or weaken a built-in, or flip deny -> allow.
#
# Uncomment and edit to activate:
#
# LIVE-SCHEMA-EXAMPLE-BEGIN
# python_hooks:
#   secret_patterns:                 # [regex, label] pairs — not {id, regex} objects
#     - ["myservice_(live|test)_[a-zA-Z0-9_-]{32,}", "MyService API token"]
#   exempt_paths:                    # substring fragments; each needs >=1 run of 3+ alnum chars
#     - "vendor/fixtures/"
#   credential_key_names:            # plain strings, folded into one extra KEY=value pattern
#     - "MYSERVICE_TOKEN"
# LIVE-SCHEMA-EXAMPLE-END
